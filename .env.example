# AutoGear Ke - Environment Variables Template
# Copy this file to .env and fill in the actual values
# IMPORTANT: Never commit .env to version control - it's in .gitignore

# ═══════════════════════════════════════════════════════════════
# REQUIRED VARIABLES (prefix with VITE_ for client-side access)
# ═══════════════════════════════════════════════════════════════

# Supabase Configuration
# Get these from your Supabase project dashboard:
# https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Cloudinary Configuration (for image uploads)
# Get these from your Cloudinary dashboard:
# https://cloudinary.com/console
# Note: Uses unsigned upload preset (no API key/secret required)
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# Admin Configuration
# The admin email that has access to the admin portal
# This provides an additional layer of security
VITE_ADMIN_EMAIL=admin@yourdomain.com

# Nominatim (OpenStreetMap Geocoding) - No API key required
VITE_NOMINATIM_URL=https://nominatim.openstreetmap.org

# ═══════════════════════════════════════════════════════════════
# SERVER-ONLY VARIABLES (do NOT prefix with VITE_)
# These are ONLY available on the server side and will NOT
# be exposed to the frontend client
# ═══════════════════════════════════════════════════════════════

# Example server-only variables (uncomment and configure if needed):
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# ADMIN_PASSWORD=your-secure-admin-password
# API_SECRET_KEY=your-secret-api-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ═══════════════════════════════════════════════════════════════
# SECURITY NOTES
# ═══════════════════════════════════════════════════════════════
# 1. Only variables prefixed with VITE_ are exposed to the browser
# 2. Server-only secrets (without VITE_ prefix) are never exposed
# 3. The Supabase ANON_KEY is safe to expose - it's designed for client use
# 4. Never expose service role keys or admin passwords to the frontend
# 5. All sensitive data should be stored in server-side environment variables
# 6. ADMIN_EMAIL is configurable for flexibility but still exposed to client
#    For maximum security, implement server-side admin authentication
